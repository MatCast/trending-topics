# Backend (.env.example)

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=/app/keys/firebase-service-account.json

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Bluesky credentials (optional)
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

# Internal API key for scheduled endpoint
INTERNAL_API_KEY=your_internal_key_here

# Rapid API key for Reddit fetching
RAPIDAPI_KEY=your_rapidapi_key_here

# App settings
LOG_LEVEL=INFO
